# 生产环境模板 — 复制为 .env 后按实际域名/密钥修改
# 目标：更低内存占用、更快响应、可安全对外服务

USE_MILVUS_LITE=true

# --- LLM（必填）---
OPENAI_API_BASE=https://api.deepseek.com
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=deepseek-v4-flash

# --- 模型：小模型显著降内存（bge-m3 约 2GB+，small 约 400MB）---
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_BACKEND=sentence_transformers

EMBEDDING_ST_FALLBACK=BAAI/bge-small-zh-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_BACKEND=cross_encoder

USE_MODELSCOPE_DOWNLOAD=true
HF_LOCAL_FILES_ONLY=true
TORCH_DEVICE=auto
USE_FP16=true
# 6GB 显存或内存紧张时可改为 2~4
EMBEDDING_BATCH_SIZE=4

# --- 检索性能（Chat SPA 默认走 /chat/stream 快速路径）---
QUERY_REWRITE_ENABLED=false
RETRIEVE_TOP_K=15
RERANK_TOP_K=5
STREAM_SKIP_RERANK=true
STREAM_RETRIEVE_TOP_K=6
STREAM_RERANK_TOP_K=3
STREAM_CONTEXT_MAX_CHARS=700

# Presidio 会额外占用内存；生产若已有网关脱敏可关闭
USE_PRESIDIO=false

# --- Redis 检索缓存（强烈推荐：重复问题秒级响应）---
# Linux 服务器：apt install redis-server 或云 Redis
# Windows 开发机：可暂不配置
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_SEARCH_CACHE_ENABLED=false
REDIS_SEARCH_CACHE_TTL_SECONDS=600

# 流式对话为主且跳过重排时，可不预热重排模型（省 ~500MB 内存，首次 /chat 会慢）
WARMUP_RERANKER_ON_STARTUP=false

# --- API 安全（本地开发可全部留空）---
# RAG_API_SECRET=
# CORS_ALLOW_ORIGINS=
# DISABLE_OPENAPI_DOCS=false
# TRUSTED_HOSTS=
# ENABLE_HSTS=false

# LangSmith 可选
LANGCHAIN_TRACING_V2=false
