# plan1 default: Milvus Lite + local rank-bm25 (no Docker)
USE_MILVUS_LITE=true

MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530

# OpenAI-compatible API（等号两侧不要加空格）
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=qwen-max

EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_ST_FALLBACK=BAAI/bge-small-zh-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base

MILVUS_COLLECTION=enterprise_rag_child_chunks

TORCH_DEVICE=auto
USE_FP16=true
EMBEDDING_BATCH_SIZE=8

# 模型下载：魔搭（国内推荐）与 Hugging Face 二选一为主；改 .env 后需重启 API
# USE_MODELSCOPE_DOWNLOAD=true
# MODELSCOPE_CACHE_DIR=
# HF_ENDPOINT=https://hf-mirror.com
# HF_HUB_CACHE=
# HF_LOCAL_FILES_ONLY=false
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 可选：仅 sentence-transformers / 仅 CrossEncoder 等见 README
# EMBEDDING_BACKEND=auto
# RERANKER_BACKEND=auto

LLAMA_CLOUD_API_KEY=
USE_PRESIDIO=true

LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=

# --- API 网关（可选）---
# RAG_API_SECRET=
# CORS_ALLOW_ORIGINS=
# DISABLE_OPENAPI_DOCS=true
# TRUSTED_HOSTS=
# ENABLE_HSTS=false
# STREAMLIT_RAG_API_SECRET=

# Legacy Docker: USE_MILVUS_LITE=false 且 MILVUS_HOST 指向 compose 服务名
